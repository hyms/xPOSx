# ==========================================
# xPOSx - Variables de Entorno (Template)
# ==========================================
# CÓMO UTILIZAR:
# 1. Copia este archivo como `.env` para desarrollo local.
# 2. Para producción (VPS), NO subas el .env al servidor.
# 3. Define estas variables en el entorno del sistema (o un archivo .env en el VPS que no esté en el repositorio).
# 4. Los scripts de despliegue (`deploy.sh`, `deploy-neon.sh`) están configurados para inyectar estas variables en los contenedores.
#
# NOTA: No uses comillas ni comentarios al final de las líneas de valores.

# --- Configuración de Base de Datos ---
POSTGRES_DB=xpos_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secretpassword
DB_HOST=db
DB_PORT=5432
# Neon DB (para despliegue con NEON)
NEON=postgresql://user:password@endpoint.region.aws.neon.tech/dbname?sslmode=require

# --- Configuración de Autenticación JWT ---
JWT_KEY=TuClaveSecretaSuperLargaYSeguraDeAlMenos32Caracteres!
JWT_ISSUER=xpos-api
JWT_AUDIENCE=xpos-clients
JWT_EXPIRE_DAYS=7

# --- Configuración del Backend (.NET) ---
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000

# --- Configuración del Frontend (Vue 3 / Vite) ---
VITE_API_URL=http://localhost:5000/api

# --- Configuración de Despliegue ---
# Estas variables son requeridas por los scripts de despliegue locales
SERVER_ADDRESS=ec2-xx-xx-xx-xx.compute-1.amazonaws.com
PEM_PATH=/ruta/a/tu/archivo.pem
