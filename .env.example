# ==========================================
# xPOSx - Variables de Entorno de Ejemplo
# ==========================================
# Copia este archivo como '.env' en la raíz 
# del proyecto y ajusta los valores.

# ------------------------------------------
# Configuración del Backend (.NET 10 API)
# ------------------------------------------

# Entorno de ejecución (Development, Staging, Production)
ASPNETCORE_ENVIRONMENT=Development
# URL en la que escucha el backend
ASPNETCORE_URLS=http://+:5000

# Credenciales de Base de Datos PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=secretpassword
DB_NAME=xpos_db

# Cadena de conexión (usada por .NET). 
# Asegúrate de que coincida con las credenciales de arriba.
ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=xpos_db;Username=postgres;Password=secretpassword;

# Configuración de Autenticación JWT
Jwt__Key=TuClaveSecretaSuperLargaYSeguraDeAlMenos32Caracteres!
Jwt__Issuer=xpos-api
Jwt__Audience=xpos-clients
Jwt__ExpireDays=7

# ------------------------------------------
# Configuración de Base de Datos (Contenedor Postgres)
# ------------------------------------------
# Estas variables son usadas por el servicio 'db' en docker-compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secretpassword
POSTGRES_DB=xpos_db

# ------------------------------------------
# Configuración del Frontend (Vue 3 / Vite)
# ------------------------------------------

# URL base para las peticiones a la API desde el cliente
VITE_API_URL=http://localhost:5000/api
# URL base para los archivos estáticos o imágenes (opcional)
VITE_PUBLIC_URL=http://localhost:5000

# ------------------------------------------
# Configuración de Despliegue (AWS EC2)
# ------------------------------------------

# Dirección IP o DNS de la instancia EC2
SERVER_ADDRESS=ec2-54-242-227-2.compute-1.amazonaws.com
# Ruta absoluta al archivo .pem para la conexión SSH
PEM_PATH=/ruta/a/tu/archivo.pem
