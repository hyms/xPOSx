# ==========================================
# xPOSx - Variables de Entorno
# ==========================================
# IMPORTANTE: No uses comillas ni comentarios al final de las líneas de valores.

# --- Configuración de Base de Datos ---
POSTGRES_DB=xpos_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secretpassword
DB_HOST=db
DB_PORT=5432

# --- Configuración de Autenticación JWT ---
JWT_KEY=TuClaveSecretaSuperLargaYSeguraDeAlMenos32Caracteres!
JWT_ISSUER=xpos-api
JWT_AUDIENCE=xpos-clients
JWT_EXPIRE_DAYS=7

# --- Configuración del Backend (.NET) ---
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000

# --- Configuración del Frontend (Vue 3 / Vite) ---
VITE_API_URL=http://localhost:5000/api

# --- Configuración de Despliegue (AWS EC2) ---
SERVER_ADDRESS=ec2-54-242-227-2.compute-1.amazonaws.com
PEM_PATH=/ruta/a/tu/archivo.pem
